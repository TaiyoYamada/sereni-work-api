# ローカル開発（supabase start が公開する PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
PORT=3001
# 最適化 Lambda（ローカルは docker compose up optimizer の RIE）
OPTIMIZER_URL=http://localhost:9000
# 本番は関数名を設定（設定時は OPTIMIZER_URL より優先）
# OPTIMIZER_FUNCTION_NAME=sereni-work-optimizer
# Supabase Admin API（アカウント発行）。supabase status の Secret キーを設定する
# SUPABASE_SERVICE_ROLE_KEY=
